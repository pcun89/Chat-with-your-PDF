# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Models (override if you want to try newer/cheaper variants)
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Chunking
CHUNK_SIZE_CHARS=1000
CHUNK_OVERLAP_CHARS=150
TOP_K=5

# CORS - comma separated list of allowed origins for the deployed frontend
ALLOWED_ORIGINS=http://localhost:5173,https://pcun89.github.io

# Vector backend: "memory" (default, zero infra) or "pgvector" (Cloud SQL)
VECTOR_BACKEND=memory

# Only needed if VECTOR_BACKEND=pgvector
DATABASE_URL=postgresql://user:password@localhost:5432/ragdb